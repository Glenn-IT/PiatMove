<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="96dp"
    android:height="96dp"
    android:viewportWidth="96"
    android:viewportHeight="96">
    <!-- rounded-square background, brand blue gradient -->
    <path android:pathData="M28,4 L68,4 Q92,4 92,28 L92,68 Q92,92 68,92 L28,92 Q4,92 4,68 L4,28 Q4,4 28,4 Z">
