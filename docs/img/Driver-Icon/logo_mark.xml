            <gradient
                android:startX="8" android:startY="8"
                android:endX="88" android:endY="88"
                android:type="linear">
                <item android:offset="0" android:color="#FF2454E0"/>
                <item android:offset="1" android:color="#FF1D43B8"/>
            </gradient>
        </aapt:attr>
    </path>
    <!-- steering wheel outer ring -->
    <path
        android:pathData="M48,48 m-26,0 a26,26 0 1,0 52,0 a26,26 0 1,0 -52,0"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="5"
        android:fillColor="#00000000"/>
    <!-- hub -->
    <path
        android:pathData="M48,48 m-8,0 a8,8 0 1,0 16,0 a8,8 0 1,0 -16,0 Z"
        android:fillColor="#FFFFFFFF"/>
    <!-- spokes -->
    <path android:pathData="M48,56 L48,70" android:strokeColor="#FFFFFFFF" android:strokeWidth="5" android:strokeLineCap="round"/>
    <path android:pathData="M41,52 L26,63" android:strokeColor="#FFFFFFFF" android:strokeWidth="5" android:strokeLineCap="round"/>
    <path android:pathData="M55,52 L70,63" android:strokeColor="#FFFFFFFF" android:strokeWidth="5" android:strokeLineCap="round"/>
    <!-- green status node -->
    <path
        android:pathData="M48,48 m-3.4,0 a3.4,3.4 0 1,0 6.8,0 a3.4,3.4 0 1,0 -6.8,0 Z"
        android:fillColor="#FF12B76A"/>
    <!-- green online badge -->
    <path
        android:pathData="M74,22 m-11,0 a11,11 0 1,0 22,0 a11,11 0 1,0 -22,0 Z"
        android:fillColor="#FF12B76A"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="4"/>
</vector>
